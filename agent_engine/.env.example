# ============================================================
#  全屋智能 Multi-Agent 系统 - 环境变量配置
#  复制此文件为 .env 并填入你的配置
#  cp .env.example .env
# ============================================================

# ========== LLM 配置 ==========
# 可选值: mock / openai / deepseek / qwen
# mock: 使用规则模拟（无需API Key，适合演示）
# openai/deepseek/qwen: 接入真实大模型
LLM_PROVIDER=mock

# 接入真实大模型时取消注释并填写:
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# DeepSeek 示例:
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ========== 服务配置 ==========
AGENT_ENGINE_HOST=0.0.0.0
AGENT_ENGINE_PORT=8081
NODE_SERVER_URL=http://localhost:8080

# ========== Home Assistant 配置 ==========
# 设为 true 启用真实 HA 连接，false 使用仿真数据
HA_ENABLED=false
HA_URL=http://homeassistant.local:8123

# HA Long-Lived Access Token
# 获取方式: HA → 用户头像 → 安全 → 长期访问令牌 → 创建令牌
HA_TOKEN=your-long-lived-access-token

# HA Entity ID 映射 (根据你的实际设备修改)
# 查看你的 Entity: HA → 开发者工具 → 状态

# -- 卧室 --
# HA_ENTITY_BEDROOM_TEMP=sensor.bedroom_temperature
# HA_ENTITY_BEDROOM_HUMIDITY=sensor.bedroom_humidity
# HA_ENTITY_BEDROOM_PRESENCE=binary_sensor.bedroom_presence
# HA_ENTITY_BEDROOM_PIR=binary_sensor.bedroom_motion
# HA_ENTITY_BEDROOM_DOOR=binary_sensor.bedroom_door
# HA_ENTITY_BEDROOM_AC=climate.bedroom_ac

# -- 客厅 --
# HA_ENTITY_LIVING_TEMP=sensor.living_room_temperature
# HA_ENTITY_LIVING_HUMIDITY=sensor.living_room_humidity
# HA_ENTITY_LIVING_PRESENCE=binary_sensor.living_room_presence
# HA_ENTITY_LIVING_AC=climate.living_room_ac

# -- 卫生间 --
# HA_ENTITY_BATH_TEMP=sensor.bathroom_temperature
# HA_ENTITY_BATH_HUMIDITY=sensor.bathroom_humidity
# HA_ENTITY_BATH_PRESENCE=binary_sensor.bathroom_presence
# HA_ENTITY_BATH_FALL=binary_sensor.bathroom_fall

# -- 全局设备 --
# HA_ENTITY_DEHUMIDIFIER=humidifier.dehumidifier
# HA_ENTITY_VENTILATION=fan.ventilation
# HA_ENTITY_ALARM=notify.mobile_app

# ========== 数据存储 ==========
DB_PATH=data/smart_home.db
HISTORY_RETENTION_DAYS=30

# ========== 定时任务 ==========
# 自动分析间隔（秒），默认5分钟
AUTO_ANALYZE_INTERVAL=300
# 紧急事件冷却时间（秒）
EMERGENCY_COOLDOWN=60
